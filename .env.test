# define your env variables for the test env here
APP_SECRET=$ecretf0rt3st
KERNEL_CLASS=App\Kernel

# Separate test database so tests never touch your dev data
DATABASE_URL="postgresql://app:!password!@127.0.0.1:5432/app_test?serverVersion=16&charset=utf8"

# Use the synchronous (in-memory) transport so messages are handled
# immediately during the test — no real queue needed
MESSENGER_TRANSPORT_DSN=sync://
